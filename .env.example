# ============================================
# TELEGRAM BOT
# ============================================
# Get from @BotFather: https://t.me/BotFather
BOT_TOKEN=your_telegram_bot_token_here
# Your Telegram user ID (get from @userinfobot)
ADMIN_ID=123456789

# ============================================
# DATABASE
# ============================================
# MongoDB Atlas: https://www.mongodb.com/atlas
# Format: mongodb+srv://user:pass@cluster.mongodb.net/dbname
DATABASE_URL=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/otp_bot?retryWrites=true&w=majority

# Redis (optional but recommended for rate limiting + sessions)
# Get from Upstash: https://upstash.com/ or self-host
REDIS_URL=redis://default:password@host:port

# ============================================
# TWILIO (Cheap/VIP Mode)
# ============================================
# Get from: https://www.twilio.com/console
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# TELNYX (Cheap/VIP Mode - Global, No Restrictions)
# ============================================
# Get from: https://portal.telnyx.com/
TELNYX_API_KEY=KEYxxxxxxxxxxxxxxxxxxxxxx
TELNYX_PHONE_NUMBER=+1234567890
# Optional: Messaging Profile ID for advanced routing
TELNYX_MESSAGING_PROFILE_ID=

# ============================================
# CHEAP SMS PANEL (Cheap Mode Fallback)
# ============================================
# Use providers like: sms-activate.org, 5sim.net, smscodes.io
# Sign up, get API key from dashboard
CHEAP_PANEL_API_KEY=your_cheap_panel_key
CHEAP_PANEL_BASE_URL=https://api.sms-activate.org/stubs/handler_api.php

# ============================================
# BLOCKCHAIN (BSC - Binance Smart Chain)
# ============================================
# Your master wallet private key (KEEP SECURE!)
# Generate wallet: https://bscscan.com/ or MetaMask
MASTER_PRIVATE_KEY=0x................................................................
# BSC RPC endpoint
BSC_RPC=https://rpc.ankr.com/bsc
# USDT Contract on BSC (BEP-20)
USDT_CONTRACT=0x55d398326f99059fF775485246999027B3197955
# Block confirmations required before crediting deposit
BLOCK_CONFIRMATIONS=12

# ============================================
# SECURITY
# ============================================
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_long
# API rate limit: requests per minute
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# ============================================
# PRICING CONFIG
# ============================================
CHEAP_OTP_PRICE=0.05
VIP_MONTHLY_PRICE=10.00
BUNDLE_PRICE=5.00
BUNDLE_OTP_COUNT=100
FREE_DAILY_LIMIT=3
VIP_DAILY_LIMIT=50

# ============================================
# REFERRAL CONFIG
# ============================================
# Percentage of referral deposit that goes to referrer (0.05 = 5%)
REFERRAL_PERCENTAGE=0.05
# Minimum deposit to trigger referral reward
REFERRAL_MIN_DEPOSIT=1.00

# ============================================
# SERVER
# ============================================
PORT=3000
NODE_ENV=production
